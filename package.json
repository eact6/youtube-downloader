{
  "name": "youtube-downloader",
  "version": "1.2.1",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -w"
  },
  "build": {
    "appId": "com.antigravity.ytdlpgui",
    "productName": "YT-DLP GUI",
    "mac": {
      "category": "public.app-category.video"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "Antigravity",
  "license": "MIT",
  "description": "YouTube Downloader GUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eact6/youtube-downloader.git"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
